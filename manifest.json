{
  "manifest_version": 3,
  "name": "Dijo AI Assistant",
  "version": "1.0",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://impactgrid-dijo-api.onrender.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["dijo.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
